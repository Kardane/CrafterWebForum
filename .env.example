# Local SQLite (default)
DATABASE_URL="file:./dev.db"

# Auth
# Replace with a strong random secret in local environment
NEXTAUTH_SECRET="replace-with-long-random-secret"
# NEXTAUTH_URL="http://127.0.0.1:3000"

# Optional admin bootstrap
# ADMIN_NICKNAMES="admin_nickname_1,admin_nickname_2"

# Minecraft server verification callback
# Required for POST /api/minecraft/verify. Use the same value on the Minecraft server/plugin.
MINECRAFT_VERIFY_SECRET="replace-with-minecraft-verify-secret"
# Optional fallback for legacy plugins that cannot send Authorization.
# Comma-separated IPs or hostnames. For the current Minecraft address, stevegallery.kr resolves via SRV to stevegallery.mc.gg.
MINECRAFT_VERIFY_ALLOWED_IPS="stevegallery.kr"

# Turso (use only when DATABASE_URL starts with libsql:// or turso://)
# TURSO_DATABASE_URL="libsql://example.turso.io"
# TURSO_AUTH_TOKEN="replace-with-turso-token"

# Blob upload migration
# BLOB_READ_WRITE_TOKEN="replace-with-blob-token"

# E2E
# E2E_BASE_URL="http://127.0.0.1:3000"

# OCI WebSocket Realtime
NEXT_PUBLIC_REALTIME_WS_URL="wss://realtime.stevegallery.kr/ws"
REALTIME_BROADCAST_URL="https://realtime.stevegallery.kr/broadcast"
REALTIME_SERVER_SECRET="replace-with-realtime-server-secret"
REALTIME_JWT_SECRET="replace-with-realtime-jwt-secret"

# Web Push (VAPID)
# Generate once and keep private key secret
# VAPID_PUBLIC_KEY="BM..."
# NEXT_PUBLIC_VAPID_PUBLIC_KEY="BM..."
# VAPID_PRIVATE_KEY="..."
# VAPID_SUBJECT="mailto:admin@example.com"

# Vercel Cron auth
# CRON_SECRET="replace-with-long-random-secret"
